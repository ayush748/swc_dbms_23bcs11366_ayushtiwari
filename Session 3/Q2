--Product Engagement Momentum Shifts
WITH ordered AS (
    SELECT
        product_id,
        product_name,
        month_start,
        monthly_active_users,
        ROW_NUMBER() OVER (
            PARTITION BY product_id
            ORDER BY month_start
        ) AS rn
    FROM product_engagement
),

turnaround_points AS (
    SELECT
        d1.product_id,
        d1.product_name,
        d1.month_start AS decline_start_month,
        d4.month_start AS lowest_month,
        d4.monthly_active_users AS lowest_users,
        g1.month_start AS growth_resumed_month,
        g1.rn AS growth_start_rn
    FROM ordered d1
    JOIN ordered d2
      ON d2.product_id = d1.product_id
     AND d2.rn = d1.rn + 1
    JOIN ordered d3
      ON d3.product_id = d1.product_id
     AND d3.rn = d1.rn + 2
    JOIN ordered d4
      ON d4.product_id = d1.product_id
     AND d4.rn = d1.rn + 3
    JOIN ordered g1
      ON g1.product_id = d1.product_id
     AND g1.rn = d1.rn + 4
    JOIN ordered g2
      ON g2.product_id = d1.product_id
     AND g2.rn = d1.rn + 5
    JOIN ordered g3
      ON g3.product_id = d1.product_id
     AND g3.rn = d1.rn + 6
    WHERE
        d1.monthly_active_users > d2.monthly_active_users
        AND d2.monthly_active_users > d3.monthly_active_users
        AND d3.monthly_active_users > d4.monthly_active_users
        AND d4.monthly_active_users < g1.monthly_active_users
        AND g1.monthly_active_users < g2.monthly_active_users
        AND g2.monthly_active_users < g3.monthly_active_users
),

growth_run AS (
    SELECT
        o.product_id,
        o.rn,
        o.monthly_active_users,
        CASE
            WHEN o.monthly_active_users >
                 LAG(o.monthly_active_users) OVER (
                     PARTITION BY o.product_id
                     ORDER BY o.rn
                 )
            THEN 1
            ELSE 0
        END AS is_growth
    FROM ordered o
),

growth_end AS (
    SELECT
        t.*,
        (
            SELECT COALESCE(MIN(g.rn) - 1,
                            MAX(o2.rn))
            FROM growth_run g
            CROSS JOIN (
                SELECT MAX(rn) AS rn
                FROM ordered o2
                WHERE o2.product_id = t.product_id
            ) o2
            WHERE g.product_id = t.product_id
              AND g.rn > t.growth_start_rn
              AND g.is_growth = 0
        ) AS growth_end_rn
    FROM turnaround_points t
)

SELECT
    ge.product_name,
    ge.decline_start_month,
    ge.growth_resumed_month,
    ROUND(
        (
            MAX(o.monthly_active_users) - ge.lowest_users
        )::NUMERIC / ge.lowest_users,
        4
    ) AS growth_ratio
FROM growth_end ge
JOIN ordered o
  ON o.product_id = ge.product_id
 AND o.rn BETWEEN ge.growth_start_rn AND ge.growth_end_rn
GROUP BY
    ge.product_name,
    ge.decline_start_month,
    ge.growth_resumed_month,
    ge.lowest_users
ORDER BY ge.product_name;